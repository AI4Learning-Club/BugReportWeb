generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Permission {
  CREATE_BUG
  RETEST_BUG
  MARK_BUG_FIXED
  ADD_BUG_EVIDENCE
  DELETE_BUG
  DELETE_BUG_ACTIVITY
  CREATE_FEATURE
  UPDATE_FEATURE
  DELETE_FEATURE
  DELETE_FEATURE_ACTIVITY
  VIEW_STATS
  MANAGE_SYSTEMS
  MANAGE_ROLES
  MANAGE_USERS
  BECOME_ITEM_OWNER
  DELEGATE_ITEM_RELATED
  DELEGATE_ITEM_OWNER
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum BugStatus {
  OPEN
  FIXED
}

enum BugActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  DELETED
  SCREENSHOT_ADDED
  SCREENSHOT_REMOVED
  RUNTIME_INFO_ADDED
  RUNTIME_INFO_UPDATED
  RUNTIME_INFO_REMOVED
  RETEST_RECORDED
  OWNER_CLAIMED
  OWNER_DELEGATED
  OWNER_REVOKED
  RELATED_JOINED
  RELATED_ADDED
  RELATED_REMOVED
}

enum RetestResult {
  APPEARED
  NOT_APPEARED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FeatureStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

enum FeatureActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  DELETED
  OWNER_CLAIMED
  OWNER_DELEGATED
  OWNER_REVOKED
  RELATED_JOINED
  RELATED_ADDED
  RELATED_REMOVED
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model User {
  id                   String               @id @default(cuid())
  username             String               @unique
  passwordHash         String
  displayName          String
  status               UserStatus           @default(PENDING)
  roleId               String?
  role                 Role?                @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isAdmin              Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  createdBugs          Bug[]                @relation("BugCreator")
  ownedBugs            Bug[]                @relation("BugOwner")
  bugRelations         BugRelatedUser[]
  fixedBugs            Bug[]                @relation("BugFixer")
  deletedBugs          Bug[]                @relation("BugDeleter")
  screenshots          BugScreenshot[]
  runtimeInfos         BugRuntimeInfo[]
  retests              BugRetest[]
  bugActivities        BugActivity[]
  createdFeatures      Feature[]            @relation("FeatureCreator")
  ownedFeatures        Feature[]            @relation("FeatureOwner")
  featureRelations     FeatureRelatedUser[]
  completedFeatures    Feature[]            @relation("FeatureCompleter")
  deletedFeatures      Feature[]            @relation("FeatureDeleter")
  featureActivities    FeatureActivity[]
}

model TrackedSystem {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  owner       String?
  versionInfo String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bugs        Bug[]
  features    Feature[]
}

model Bug {
  id           String           @id @default(cuid())
  systemId     String
  system       TrackedSystem    @relation(fields: [systemId], references: [id])
  creatorId    String
  creator      User             @relation("BugCreator", fields: [creatorId], references: [id])
  ownerId      String?
  owner        User?            @relation("BugOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  title        String
  description  String
  severity     Severity         @default(MEDIUM)
  environment  String?
  steps        String?
  expected     String?
  actual       String?
  status       BugStatus        @default(OPEN)
  fixedAt      DateTime?
  fixedById    String?
  fixedBy      User?            @relation("BugFixer", fields: [fixedById], references: [id])
  deletedAt    DateTime?
  deletedById  String?
  deletedBy    User?            @relation("BugDeleter", fields: [deletedById], references: [id])
  deleteReason String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  screenshots  BugScreenshot[]
  runtimeInfos BugRuntimeInfo[]
  retests      BugRetest[]
  activities   BugActivity[]
  relatedUsers BugRelatedUser[]

  @@index([systemId])
  @@index([creatorId])
  @@index([ownerId])
  @@index([status])
  @@index([deletedAt])
  @@index([deletedById])
}

model BugRelatedUser {
  bugId  String
  bug    Bug    @relation(fields: [bugId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([bugId, userId])
  @@index([userId])
}

model BugActivity {
  id         String          @id @default(cuid())
  bugId      String
  bug        Bug             @relation(fields: [bugId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User            @relation(fields: [actorId], references: [id])
  type       BugActivityType
  note       String?
  fromStatus BugStatus?
  toStatus   BugStatus?
  changes    Json?
  context    Json?
  createdAt  DateTime        @default(now())

  @@index([bugId, createdAt])
  @@index([actorId])
  @@index([type])
}

model BugScreenshot {
  id           String   @id @default(cuid())
  bugId        String
  bug          Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)
  uploaderId   String
  uploader     User     @relation(fields: [uploaderId], references: [id])
  originalName String
  storedName   String
  path         String
  mimeType     String
  sizeBytes    Int
  caption      String?
  createdAt    DateTime @default(now())

  @@index([bugId])
}

model BugRuntimeInfo {
  id          String   @id @default(cuid())
  bugId       String
  bug         Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  title       String
  environment String?
  logText     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([bugId])
}

model BugRetest {
  id        String       @id @default(cuid())
  bugId     String
  bug       Bug          @relation(fields: [bugId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  result    RetestResult
  note      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([bugId, userId])
  @@index([bugId])
}

model Feature {
  id            String               @id @default(cuid())
  systemId      String
  system        TrackedSystem        @relation(fields: [systemId], references: [id])
  creatorId     String
  creator       User                 @relation("FeatureCreator", fields: [creatorId], references: [id])
  ownerId       String?
  owner         User?                @relation("FeatureOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  title         String
  description   String
  status        FeatureStatus        @default(PLANNED)
  priority      Severity             @default(MEDIUM)
  completedAt   DateTime?
  completedById String?
  completedBy   User?                @relation("FeatureCompleter", fields: [completedById], references: [id])
  deletedAt     DateTime?
  deletedById   String?
  deletedBy     User?                @relation("FeatureDeleter", fields: [deletedById], references: [id])
  deleteReason  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  relatedUsers  FeatureRelatedUser[]
  activities    FeatureActivity[]

  @@index([systemId])
  @@index([creatorId])
  @@index([ownerId])
  @@index([status])
  @@index([deletedAt])
}

model FeatureActivity {
  id         String              @id @default(cuid())
  featureId  String
  feature    Feature             @relation(fields: [featureId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User                @relation(fields: [actorId], references: [id])
  type       FeatureActivityType
  note       String?
  fromStatus FeatureStatus?
  toStatus   FeatureStatus?
  changes    Json?
  context    Json?
  createdAt  DateTime            @default(now())

  @@index([featureId, createdAt])
  @@index([actorId])
  @@index([type])
}

model FeatureRelatedUser {
  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([featureId, userId])
  @@index([userId])
}
